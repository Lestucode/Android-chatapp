<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F2F2"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:elevation="4dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/chat_toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="?attr/colorPrimary"
            app:titleTextColor="#333333"
            app:navigationIconTint="#333333"
            app:titleCentered="true" />
            
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMessages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="12dp"
        android:clipToPadding="false"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="@android:color/white"
        android:gravity="bottom"
        android:elevation="8dp">
        
        <ImageView
            android:id="@+id/btnEmoji"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginBottom="6dp"
            android:layout_marginEnd="8dp"
            android:src="@android:drawable/ic_menu_myplaces"
            app:tint="#888888"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="6dp"/>
        
        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#F5F5F5"
            app:strokeWidth="0dp">
            
            <EditText
                android:id="@+id/etMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="输入消息..."
                android:background="@null"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:minHeight="48dp"
                android:maxLines="4"
                android:textSize="16sp"
                android:inputType="textMultiLine"/>
        </com.google.android.material.card.MaterialCardView>

        <ImageView
            android:id="@+id/btnAdd"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginBottom="6dp"
            android:layout_marginStart="8dp"
            android:src="@android:drawable/ic_input_add"
            app:tint="#888888"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="6dp"/>
            
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnSend"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginBottom="4dp"
            app:fabSize="mini"
            app:elevation="2dp"
            app:tint="@android:color/white"
            app:backgroundTint="#007AFF"
            android:src="@android:drawable/ic_menu_send" />
    </LinearLayout>

    <!-- Expandable Tools Panel -->
    <LinearLayout
        android:id="@+id/llToolsPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="24dp"
        android:background="#F2F2F2"
        android:visibility="gone">

        <!-- Image Tool -->
        <LinearLayout
            android:id="@+id/btnToolImage"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@android:drawable/ic_menu_gallery"
                android:background="@drawable/tool_bg"
                android:padding="12dp"
                app:tint="#333333"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="图片"
                android:textSize="12sp"
                android:textColor="#666666"/>
        </LinearLayout>

        <!-- Video Tool -->
        <LinearLayout
            android:id="@+id/btnToolVideo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@android:drawable/ic_menu_camera"
                android:background="@drawable/tool_bg"
                android:padding="12dp"
                app:tint="#333333"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="视频"
                android:textSize="12sp"
                android:textColor="#666666"/>
        </LinearLayout>

        <!-- File Tool -->
        <LinearLayout
            android:id="@+id/btnToolFile"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@android:drawable/ic_menu_agenda"
                android:background="@drawable/tool_bg"
                android:padding="12dp"
                app:tint="#333333"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="文件"
                android:textSize="12sp"
                android:textColor="#666666"/>
        </LinearLayout>
        
        <Space
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"/>
            
    </LinearLayout>

    <!-- Emoji Picker Panel (Simple grid or placeholder) -->
    <FrameLayout
        android:id="@+id/flEmojiPanel"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:background="#F2F2F2"
        android:visibility="gone">
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvEmojis"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="8dp"/>
    </FrameLayout>

</LinearLayout>