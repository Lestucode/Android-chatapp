<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/friend_request"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="4dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="?attr/colorOutlineVariant">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        >

        <!-- Friend Avatar -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/my_avater"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/dinosaur"
            app:shapeAppearanceOverlay="@style/CircleImageView"
            app:strokeColor="?attr/colorOutline"
            app:strokeWidth="1dp"/>

        <!-- Middle Content Area -->
        <LinearLayout
            android:layout_width="100dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="13dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Friend Name -->
            <TextView
                android:id="@+id/nickname"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:textColor="@color/system_accent3_900"
                tools:text="昵称" />

            <!-- Last Message -->
            <TextView
                android:id="@+id/tv_apply_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="@color/system_accent3_800"
                tools:text="向你发起好友申请" />
        </LinearLayout>
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        >
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_agree"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cornerRadius="100dp"
            android:layout_marginTop="4dp"
            android:text="同意"
            android:textSize="14sp"
            android:backgroundTint="@color/system_accent3_50"
            />
        <TextView
            android:id="@+id/tv_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="已同意"
            android:visibility="gone"
            android:textColor="?attr/colorOutline"
            android:textSize="14sp"
            />
    </LinearLayout>


    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
